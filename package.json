{
  "name": "heatripscreener",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./app/css/input.css -o ./app/styles.css",
    "build:css:min": "tailwindcss -i ./app/css/input.css -o ./app/styles.css --minify",
    "prefetch:tickers": "tsx scripts/prefetch-tickers.ts",
    "fetch:logos": "tsx scripts/fetch-exchange-logos.ts",
    "telegram:login": "tsx scripts/telegram-login.ts",
    "railway:telegram-session": "bash scripts/railway-set-telegram-session.sh",
    "railway:unstick": "bash scripts/railway-unstick-queue.sh",
    "build": "npm run build:css && npm run prefetch:tickers",
    "start": "NODE_OPTIONS='--dns-result-order=ipv4first' tsx src/server/index.ts",
    "ingest": "tsx src/ingestion/index.ts",
    "server": "tsx src/server/index.ts"
  },
  "dependencies": {
    "avsc": "^5.7.9",
    "telegram": "^2.26.22",
    "tsx": "^4.19.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.0"
  }
}
